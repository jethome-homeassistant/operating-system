From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Nikita Maslov <nikitamalco203@gmail.com>
Date: Wed, 18 Jun 2026 14:13:00 +0300
Subject: arm64: dts: jethub-j80: add gpio-line-names for Zigbee

Name the Zigbee EFR32 control lines on the AO GPIO bank (GPIOAO_6 reset,
GPIOAO_9 boot) so they can be addressed by name via libgpiod instead of
chip+line number, matching the jethub hardware-init script. j100/j200
already carry such names; this brings j80 in line.
---
 .../boot/dts/amlogic/meson-gxl-s905w-jethome-jethub-j80.dts   | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

diff --git a/arch/arm64/boot/dts/amlogic/meson-gxl-s905w-jethome-jethub-j80.dts b/arch/arm64/boot/dts/amlogic/meson-gxl-s905w-jethome-jethub-j80.dts
--- a/arch/arm64/boot/dts/amlogic/meson-gxl-s905w-jethome-jethub-j80.dts
+++ b/arch/arm64/boot/dts/amlogic/meson-gxl-s905w-jethome-jethub-j80.dts
@@ -245,3 +245,17 @@
 		status = "okay";
 	};
 };
+
+&gpio_ao {
+	gpio-line-names =
+		"",            /* GPIOAO_0 */
+		"",            /* GPIOAO_1 */
+		"",            /* GPIOAO_2 */
+		"",            /* GPIOAO_3 */
+		"",            /* GPIOAO_4 */
+		"",            /* GPIOAO_5 */
+		"ZigBeeRESET", /* GPIOAO_6 */
+		"",            /* GPIOAO_7 */
+		"",            /* GPIOAO_8 */
+		"ZigBeeBOOT";  /* GPIOAO_9 */
+};
